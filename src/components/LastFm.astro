---
const apiKey = import.meta.env.PUBLIC_LASTFM_API_KEY;
const username = import.meta.env.PUBLIC_LASTFM_USERNAME;
---

<div class="lastfm-widget" id="lastfm-widget" data-api-key={apiKey} data-username={username}>
  <h2>// NOW SCROBBLING</h2>

  <!-- TABS -->
  <div class="lfm-tabs">
    <button class="lfm-tab active" data-tab="recent">recent</button>
    <button class="lfm-tab" data-tab="top-tracks">top tracks</button>
    <button class="lfm-tab" data-tab="top-artists">top artists</button>
  </div>

  <!-- PANELS -->
  <div class="lfm-panel active" id="panel-recent">
    <div class="lfm-list" id="list-recent">
      <div class="lfm-loading">fetching scrobbles<span class="lfm-dots"></span></div>
    </div>
  </div>

  <div class="lfm-panel" id="panel-top-tracks">
    <div class="lfm-period">
      <span class="period-label">period:</span>
      <button class="period-btn active" data-period="7day">7d</button>
      <button class="period-btn" data-period="1month">1mo</button>
      <button class="period-btn" data-period="12month">1yr</button>
      <button class="period-btn" data-period="overall">all</button>
    </div>
    <div class="lfm-list" id="list-top-tracks">
      <div class="lfm-loading">fetching tracks<span class="lfm-dots"></span></div>
    </div>
  </div>

  <div class="lfm-panel" id="panel-top-artists">
    <div class="lfm-list" id="list-top-artists">
      <div class="lfm-loading">fetching artists<span class="lfm-dots"></span></div>
    </div>
  </div>

  <div class="lfm-footer">
    <span class="lfm-user">📻 <a href={`https://www.last.fm/user/${username}`} target="_blank" rel="noopener">last.fm/{username}</a></span>
    <span class="lfm-total" id="lfm-total"></span>
  </div>
</div>

<script lang="ts">
  const widget   = document.getElementById('lastfm-widget') as HTMLElement;
  const apiKey   = widget.dataset.apiKey ?? '';
  const username = widget.dataset.username ?? '';
  const BASE     = 'https://ws.audioscrobbler.com/2.0/';
  let topTracksPeriod = '7day';

  // ── FETCH HELPERS ──────────────────────────
  async function fetchRecent() {
    const res  = await fetch(`${BASE}?method=user.getrecenttracks&user=${username}&api_key=${apiKey}&format=json&limit=8`);
    const data = await res.json();
    return data.recenttracks?.track ?? [];
  }

  async function fetchTopTracks(period: string = '7day') {
    const res  = await fetch(`${BASE}?method=user.gettoptracks&user=${username}&api_key=${apiKey}&format=json&limit=8&period=${period}`);
    const data = await res.json();
    return data.toptracks?.track ?? [];
  }

  async function fetchTopArtists() {
    const res  = await fetch(`${BASE}?method=user.gettopartists&user=${username}&api_key=${apiKey}&format=json&limit=8&period=overall`);
    const data = await res.json();
    return data.topartists?.artist ?? [];
  }

  async function fetchUserInfo() {
    const res  = await fetch(`${BASE}?method=user.getinfo&user=${username}&api_key=${apiKey}&format=json`);
    const data = await res.json();
    return data.user;
  }

  // ── RENDER HELPERS ─────────────────────────
  function renderRecent(tracks: any[]) {
    if (!tracks.length) return '<div class="lfm-empty">no recent tracks found</div>';
    return tracks.map((t: any, i: number) => {
      const isNowPlaying = t['@attr']?.nowplaying === 'true';
      const artist = t.artist?.['#text'] ?? t.artist?.name ?? '—';
      const name   = t.name ?? '—';
      const date   = isNowPlaying ? '▶ now playing' : (t.date?.['#text'] ?? '');
      const img    = t.image?.[1]?.['#text'];
      return `
        <div class="lfm-row ${isNowPlaying ? 'now-playing' : ''}">
          <span class="lfm-index">${isNowPlaying ? '▶' : String(i + 1).padStart(2, '0')}</span>
          ${img ? `<img class="lfm-art" src="${img}" alt="" loading="lazy" />` : '<div class="lfm-art-placeholder"></div>'}
          <div class="lfm-info">
            <div class="lfm-track">${name}</div>
            <div class="lfm-artist">${artist}</div>
          </div>
          <div class="lfm-date">${date}</div>
        </div>`;
    }).join('');
  }

  function renderTopTracks(tracks: any[]) {
    if (!tracks.length) return '<div class="lfm-empty">no data for this period</div>';
    return tracks.map((t: any, i: number) => {
      const artist = t.artist?.name ?? '—';
      const name   = t.name ?? '—';
      const plays  = parseInt(t.playcount ?? 0).toLocaleString();
      const img    = t.image?.[1]?.['#text'];
      return `
        <div class="lfm-row">
          <span class="lfm-index">${String(i + 1).padStart(2, '0')}</span>
          ${img ? `<img class="lfm-art" src="${img}" alt="" loading="lazy" />` : '<div class="lfm-art-placeholder"></div>'}
          <div class="lfm-info">
            <div class="lfm-track">${name}</div>
            <div class="lfm-artist">${artist}</div>
          </div>
          <div class="lfm-plays">${plays} plays</div>
        </div>`;
    }).join('');
  }

  function renderTopArtists(artists: any[]) {
    if (!artists.length) return '<div class="lfm-empty">no artist data found</div>';
    return artists.map((a: any, i: number) => {
      const name  = a.name ?? '—';
      const plays = parseInt(a.playcount ?? 0).toLocaleString();
      const img   = a.image?.[1]?.['#text'];
      return `
        <div class="lfm-row">
          <span class="lfm-index">${String(i + 1).padStart(2, '0')}</span>
          ${img ? `<img class="lfm-art lfm-art-round" src="${img}" alt="" loading="lazy" />` : '<div class="lfm-art-placeholder lfm-art-round"></div>'}
          <div class="lfm-info">
            <div class="lfm-track">${name}</div>
            <div class="lfm-artist">artist</div>
          </div>
          <div class="lfm-plays">${plays} scrobbles</div>
        </div>`;
    }).join('');
  }

  // ── LOAD DATA ──────────────────────────────
  async function loadRecent() {
    const el = document.getElementById('list-recent');
    if (!el) return;
    try {
      const tracks = await fetchRecent();
      el.innerHTML = renderRecent(tracks);
    } catch {
      el.innerHTML = '<div class="lfm-empty lfm-error">failed to load — check API key</div>';
    }
  }

  async function loadTopTracks(period: string = topTracksPeriod) {
    const el = document.getElementById('list-top-tracks');
    if (!el) return;
    el.innerHTML = '<div class="lfm-loading">fetching tracks<span class="lfm-dots"></span></div>';
    try {
      const tracks = await fetchTopTracks(period);
      el.innerHTML = renderTopTracks(tracks);
    } catch {
      el.innerHTML = '<div class="lfm-empty lfm-error">failed to load</div>';
    }
  }

  async function loadTopArtists() {
    const el = document.getElementById('list-top-artists');
    if (!el) return;
    try {
      const artists = await fetchTopArtists();
      el.innerHTML = renderTopArtists(artists);
    } catch {
      el.innerHTML = '<div class="lfm-empty lfm-error">failed to load</div>';
    }
  }

  async function loadUserInfo() {
    try {
      const user  = await fetchUserInfo();
      const total = parseInt(user.playcount ?? 0).toLocaleString();
      const el    = document.getElementById('lfm-total');
      if (el) el.textContent = `${total} total scrobbles`;
    } catch { /* silent */ }
  }

  // ── TABS ───────────────────────────────────
  document.querySelectorAll('.lfm-tab').forEach(btn => {
    btn.addEventListener('click', () => {
      const tab = (btn as HTMLElement).dataset.tab;
      document.querySelectorAll('.lfm-tab').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.lfm-panel').forEach(p => p.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById(`panel-${tab}`)?.classList.add('active');
      if (tab === 'top-tracks') loadTopTracks();
      if (tab === 'top-artists') loadTopArtists();
    });
  });

  // ── PERIOD BUTTONS ─────────────────────────
  document.querySelectorAll('.period-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.period-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      topTracksPeriod = (btn as HTMLElement).dataset.period ?? '7day';
      loadTopTracks(topTracksPeriod);
    });
  });

  // ── INIT ───────────────────────────────────
  loadRecent();
  loadUserInfo();
</script>

<style>
  .lastfm-widget {
    max-width: 620px;
    margin-top: 8px;
    margin-bottom: 32px;
  }

  /* ── TABS ── */
  .lfm-tabs {
    display: flex;
    gap: 0;
    margin-bottom: 0;
    border-bottom: 1px solid var(--border);
  }
  .lfm-tab {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--text-dim);
    background: none;
    border: 1px solid transparent;
    border-bottom: none;
    padding: 6px 14px;
    cursor: pointer;
    transition: color 0.15s, background 0.15s;
    border-radius: 4px 4px 0 0;
    margin-bottom: -1px;
  }
  .lfm-tab:hover { color: var(--text); }
  .lfm-tab.active {
    color: var(--accent);
    background: var(--bg);
    border-color: var(--border);
    border-bottom-color: var(--bg);
  }

  /* ── PANELS ── */
  .lfm-panel { display: none; padding-top: 8px; }
  .lfm-panel.active { display: block; }

  /* ── PERIOD BUTTONS ── */
  .lfm-period {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 0 8px;
  }
  .period-label { font-size: 11px; color: var(--text-dim); }
  .period-btn {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text-dim);
    background: var(--bg-dark);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 2px 8px;
    cursor: pointer;
    transition: color 0.15s, border-color 0.15s;
  }
  .period-btn:hover { color: var(--text); border-color: var(--text-dim); }
  .period-btn.active { color: var(--accent); border-color: var(--accent); background: rgba(220,79,10,0.06); }

  /* ── ROWS ── */
  .lfm-list { display: flex; flex-direction: column; }

  .lfm-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 7px 0;
    border-bottom: 1px solid var(--border);
    transition: background 0.1s, padding-left 0.15s;
  }
  .lfm-row:hover { padding-left: 6px; }
  .lfm-row.now-playing { background: rgba(220,79,10,0.04); }
  .lfm-row.now-playing .lfm-track { color: var(--accent); }

  .lfm-index {
    font-size: 11px;
    color: var(--text-dim);
    width: 20px;
    flex-shrink: 0;
    text-align: right;
  }
  .lfm-art {
    width: 32px;
    height: 32px;
    object-fit: cover;
    border-radius: 3px;
    flex-shrink: 0;
    border: 1px solid var(--border);
  }
  .lfm-art-round { border-radius: 50%; }
  .lfm-art-placeholder {
    width: 32px;
    height: 32px;
    background: var(--bg-dark);
    border: 1px solid var(--border);
    border-radius: 3px;
    flex-shrink: 0;
  }

  .lfm-info { flex: 1; min-width: 0; }
  .lfm-track {
    font-size: 13px;
    font-weight: 500;
    color: var(--blue);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .lfm-artist {
    font-size: 11px;
    color: var(--text-dim);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .lfm-date  { font-size: 11px; color: var(--text-dim); flex-shrink: 0; text-align: right; max-width: 110px; }
  .lfm-plays { font-size: 11px; color: var(--green); flex-shrink: 0; text-align: right; }

  /* ── LOADING ── */
  .lfm-loading {
    font-size: 12px;
    color: var(--text-dim);
    padding: 16px 0;
  }
  .lfm-dots::after {
    content: '...';
    animation: dots 1.2s steps(4, end) infinite;
  }
  @keyframes dots {
    0%  { content: '';    }
    25% { content: '.';   }
    50% { content: '..';  }
    75% { content: '...'; }
  }

  .lfm-empty { font-size: 12px; color: var(--text-dim); padding: 16px 0; }
  .lfm-error { color: var(--accent); }

  /* ── FOOTER ── */
  .lfm-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 0 0;
    font-size: 11px;
    color: var(--text-dim);
  }
  .lfm-user a { color: var(--text-dim); text-decoration: none; transition: color 0.15s; }
  .lfm-user a:hover { color: var(--accent); }
</style>
